    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.82.0",
    "shadcn": "^4.13.1",
